# Compose-shaped config. `cp backend/.env.example backend/.env` once.
# Host `DATABASE__URL=...@postgres` only resolves inside the compose network;
# for host-side tools (pre-push pytest, local uvicorn) copy
# `backend/.env.local.example` → `backend/.env.local` to override with
# `@localhost:5432`. Pydantic-settings loads `.env.local` after `.env` so the
# override wins. See issue #67.

ENV=dev
LOG_LEVEL=INFO

DATABASE__URL=postgresql+asyncpg://scrumban:scrumban@postgres:5432/scrumban

REDIS__URL=redis://redis:6379/0

JWT__SECRET=change-me-in-prod
JWT__ACCESS_TTL_MINUTES=15
JWT__REFRESH_TTL_DAYS=30

TELEGRAM__BOT_TOKEN=
TELEGRAM__BOT_USERNAME=
TELEGRAM__MODE=polling
TELEGRAM__LINK_CODE_TTL_MINUTES=15

STORAGE__ENDPOINT_URL=http://minio:9000
STORAGE__ACCESS_KEY=minioadmin
STORAGE__SECRET_KEY=minioadmin
STORAGE__BUCKET=attachments

CORS_ORIGINS=["http://localhost:5173"]
