# backend/.env.local — host-shell overrides, optional.
#
# Loaded by pydantic-settings AFTER `backend/.env`, so any key set here wins
# over the compose-shaped defaults in `.env`. Gitignored. Not consumed by
# `deploy/docker-compose.yml` (compose only loads `backend/.env`).
#
# One-time setup: `cp backend/.env.local.example backend/.env.local`.
# After that, `git push` on the host runs the pre-push pytest hook against
# the compose-published Postgres port (localhost:5432) without needing
# `DATABASE__URL=...@localhost:5432/...` prefixed on every push. See issue #67.

DATABASE__URL=postgresql+asyncpg://scrumban:scrumban@localhost:5432/scrumban

# If you run Redis host-side too (rare — usually you just leave the compose
# redis running), uncomment:
# REDIS__URL=redis://localhost:6379/0
